<Window x:Class="UiaPeek.PathFinder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:t="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:editors="http://wpfcontrols.com/"
        mc:Ignorable="d"
        WindowStyle="ThreeDBorderWindow"
        Title="UiaPeek Path Finder v1.0"
        ResizeMode="CanResizeWithGrip" ShowInTaskbar="True" ShowActivated="True"
        Height="600"
        Width="400">
  <Grid x:Name="RootGrid">
    <Label Content="UiaPeek Path Finder v1.0"
           HorizontalAlignment="Left"
           Margin="10,10,0,0"
           VerticalAlignment="Top"
           Height="40"
           Width="330"
           FontSize="22"
           FontWeight="Bold" />

    <TextBox HorizontalAlignment="Left"
             Margin="10,55,0,0"
             TextWrapping="Wrap"
             VerticalAlignment="Top"
             Width="330"
             Name="TxbPath"
             Height="76"
             VerticalScrollBarVisibility="Auto"
             HorizontalScrollBarVisibility="Auto" />

    <StackPanel Margin="10,162,0,0" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Left">
      <Button Content="▶ _Start"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              RenderTransformOrigin="-0.57,1.481"
              Height="30"
              Width="70"
              Name="BtnStartStop"
              Click="BtnStartStop_Click"
              AccessKeyManager.AccessKeyPressed="BtnStartStop_AccessKeyPressed"
              Cursor="Hand" />

      <Button Content="Set _Position"
              HorizontalAlignment="Left"
              Margin="20,0,0,0"
              VerticalAlignment="Top"
              Height="30"
              Width="70"
              Name="BtnSetPosition"
              Click="BtnSetPosition_Click"
              AccessKeyManager.AccessKeyPressed="BtnSetPosition_AccessKeyPressed"
              Cursor="Hand" />

      <Button Content="_Test Path"
              HorizontalAlignment="Left"
              Margin="20,0,0,0"
              VerticalAlignment="Top"
              RenderTransformOrigin="-0.57,1.481"
              Height="30"
              Width="70"
              Name="BtnTestPath"
              Click="BtnTestPath_Click"
              AccessKeyManager.AccessKeyPressed="BtnTestPath_AccessKeyPressed"
              Cursor="Hand" />

      <Button Content="Open log" Margin="20,0,0,0" Padding="5" x:Name="OpenLogBtn" Click="OpenLogBtn_OnClick"></Button>
    </StackPanel>

    <StackPanel Margin="11,133,0,0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top">
      <Label Content="Idle"
             HorizontalAlignment="Left"
             Name="LblStatus"
             VerticalAlignment="Top"
             RenderTransformOrigin="0.405,-0.33"
             Width="55"
             Visibility="Visible"
             FontSize="9" />

      <Label Content="0000.000s"
             HorizontalAlignment="Left"
             Name="LblTime"
             VerticalAlignment="Top"
             RenderTransformOrigin="0.405,-0.33"
             Width="70"
             Visibility="Visible"
             FontSize="9" />

      <Label Content="X:"
             HorizontalAlignment="Left"
             VerticalAlignment="Top"
             RenderTransformOrigin="-6.268,-0.931" />

      <TextBox HorizontalAlignment="Left"
               Margin="5,5,0,0"
               TextWrapping="Wrap"
               VerticalAlignment="Top"
               Width="45"
               Name="TxbAxisX" />

      <Label Content="Y:"
             HorizontalAlignment="Left"
             VerticalAlignment="Top" />

      <TextBox HorizontalAlignment="Left"
               Margin="5,5,0,0"
               TextWrapping="Wrap"
               VerticalAlignment="Top"
               Width="45"
               Name="TxbAxisY" />
    </StackPanel>

    <StackPanel Margin="0,201,0,0" Orientation="Horizontal" VerticalAlignment="Top">
      <Label Content="Faster"
             HorizontalAlignment="Left"
             Margin="11,0,0,0"
             VerticalAlignment="Top"
             RenderTransformOrigin="0.405,-0.33" />

      <Slider HorizontalAlignment="Left"
              Margin="5,0,5,0"
              VerticalAlignment="Center"
              Width="246"
              Minimum="500"
              Maximum="3000"
              Value="1000"
              Name="SldRefreshSpeed" ValueChanged="SldRefreshSpeed_ValueChanged" />

      <Label Content="Slower"
             HorizontalAlignment="Left"
             Margin="0,0,0,0"
             VerticalAlignment="Top"
             RenderTransformOrigin="0.263,0.21" Height="26" Width="45" />
    </StackPanel>

    <StackPanel Orientation="Vertical" Margin="10,250,10,10" VerticalAlignment="Top">
      <Label>Process filter (only log for the following process name):</Label>
      <!--<TextBox x:Name="FilterTextBox" Height="30" FontFamily="Calibri" Text="iomsclient" FontSize="20"></TextBox>-->
      <!--<t:AutoSelectTextBox x:Name="FilterTextBox" FontFamily="Calibri" FontSize="20">iomsclient</t:AutoSelectTextBox>-->
      <editors:AutoCompleteTextBox x:Name="FilterTextBox" FontFamily="Calibri" FontSize="20" Text="iomsclient" Margin="0,5,5,5"
                                   Provider="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ProcessesNamesProvider}">

      </editors:AutoCompleteTextBox>

      <ListBox Visibility="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ShowProcessesListBox}"
               ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Processes}">
      </ListBox>
    </StackPanel>
  </Grid>
</Window>