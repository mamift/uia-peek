<Window x:Class="UiaPeek.PathFinder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:t="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:editors="http://wpfcontrols.com/"
        xmlns:pathFinder="clr-namespace:UiaPeek.PathFinder"
        mc:Ignorable="d"
        WindowStyle="ThreeDBorderWindow"
        Title="UiaPeek Path Finder v1.0"
        ResizeMode="CanResizeWithGrip" ShowInTaskbar="True" ShowActivated="True"
        Height="600"
        Width="400">
  <Grid x:Name="RootGrid">
    <TabControl Margin="0,10,0,0">
      <TabItem Name="Locator" Header="Locator">
        <Grid>
          <pathFinder:LocatorTabView x:Name="LocatorTabView"></pathFinder:LocatorTabView>
        </Grid>
      </TabItem>
      <TabItem Name="Recording" Header="Recording">
      </TabItem>
    </TabControl>
  </Grid>
</Window>