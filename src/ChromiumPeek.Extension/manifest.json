{
	"manifest_version": 3,
	"name": "ChromiumPeek Recorder",
	"version": "0.0.1",
	"description": "Test extension for ChromiumPeek.",
	"action": {
		"default_popup": "user-interface/popup.html",
		"default_title": "ChromiumPeek"
	},
	"permissions": [
		"scripting",
		"activeTab"
	],
	"host_permissions": [
		"http://localhost:9956/*"
	],
	"background": {
		"service_worker": "js/background.js",
		"type": "module"
	},
	"content_scripts": [
		{
			"matches": [ "<all_urls>" ],
			"js": [ "js/content-script.js" ],
			"run_at": "document_idle"
		}
	]
}
